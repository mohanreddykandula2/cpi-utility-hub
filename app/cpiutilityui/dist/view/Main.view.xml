<mvc:View
    id="mainView"
    controllerName="com.cpi.utility.cpiutilityui.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:u="sap.ui.unified"
>
    <Page
        id="mainPage"
        title="CPI Utility Hub"
    >
        <content>
            <VBox
                id="mainContainer"
                class="sapUiMediumMargin"
                width="100%"
            >
                <MessageStrip
                    id="introMessage"
                    text="Rename SAP CPI script resources safely using a local ZIP or a secure BTP Destination."
                    type="Information"
                    showIcon="true"
                    class="sapUiSmallMarginBottom"
                />

                <IconTabBar
                    id="workflowTabs"
                    expandable="false"
                    selectedKey="{/selectedTab}"
                >
                    <items>
                        <IconTabFilter
                            id="sourceTab"
                            key="source"
                            icon="sap-icon://upload"
                            text="Source"
                        >
                            <VBox
                                id="sourceContainer"
                                class="sapUiMediumMargin"
                            >
                                <Panel
                                    id="sourceModePanel"
                                    headerText="Choose Artifact Source"
                                    width="auto"
                                >
                                    <VBox
                                        id="sourceModeContainer"
                                        class="sapUiSmallMargin"
                                    >
                                        <SegmentedButton
                                            id="sourceModeSelector"
                                            selectedKey="{/sourceMode}"
                                            selectionChange=".onSourceModeChanged"
                                        >
                                            <items>
                                                <SegmentedButtonItem
                                                    id="cpiSourceMode"
                                                    key="cpi"
                                                    text="Download from CPI"
                                                    icon="sap-icon://cloud"
                                                />
                                                <SegmentedButtonItem
                                                    id="uploadSourceMode"
                                                    key="upload"
                                                    text="Upload ZIP"
                                                    icon="sap-icon://upload"
                                                />
                                            </items>
                                        </SegmentedButton>

                                        <VBox
                                            id="cpiSourceBox"
                                            visible="{= ${/sourceMode} === 'cpi' }"
                                            class="sapUiMediumMarginTop"
                                        >
                                            <Label
                                                id="iflowIdLabel"
                                                text="iFlow ID"
                                                labelFor="iflowIdInput"
                                            />
                                            <Input
                                                id="iflowIdInput"
                                                value="{/iflowId}"
                                                valueLiveUpdate="true"
                                                placeholder="Enter CPI iFlow technical ID"
                                                liveChange=".onIflowIdChanged"
                                            />
                                            <OverflowToolbar
                                                id="cpiSourceToolbar"
                                            >
                                                <ToolbarSpacer
                                                    id="cpiSourceToolbarSpacer"
                                                />
                                                <Button
                                                    id="downloadFromCpiButton"
                                                    text="Download and Analyze"
                                                    type="Emphasized"
                                                    icon="sap-icon://download-from-cloud"
                                                    press=".onDownloadFromCpi"
                                                    enabled="{/canDownloadFromCpi}"
                                                />
                                            </OverflowToolbar>
                                        </VBox>

                                        <VBox
                                            id="uploadSourceBox"
                                            visible="{= ${/sourceMode} === 'upload' }"
                                            class="sapUiMediumMarginTop"
                                        >
                                            <Text
                                                id="uploadHelpText"
                                                text="Upload an exported SAP CPI iFlow ZIP from your local system."
                                            />
                                            <u:FileUploader
                                                id="artifactUploader"
                                                width="100%"
                                                fileType="zip"
                                                sameFilenameAllowed="true"
                                                change=".onFileSelected"
                                                placeholder="Choose SAP CPI iFlow ZIP"
                                            />
                                            <OverflowToolbar
                                                id="uploadSourceToolbar"
                                            >
                                                <ToolbarSpacer
                                                    id="uploadSourceToolbarSpacer"
                                                />
                                                <Button
                                                    id="analyzeButton"
                                                    text="Analyze Artifact"
                                                    type="Emphasized"
                                                    icon="sap-icon://inspect"
                                                    press=".onAnalyzeArtifact"
                                                    enabled="{/hasFile}"
                                                />
                                            </OverflowToolbar>
                                        </VBox>
                                    </VBox>
                                </Panel>
                            </VBox>
                        </IconTabFilter>

                        <IconTabFilter
                            id="reviewTab"
                            key="review"
                            icon="sap-icon://activity-items"
                            text="Review"
                        >
                            <VBox
                                id="reviewContainer"
                                class="sapUiMediumMargin"
                            >
                                <Panel
                                    id="summaryPanel"
                                    headerText="Artifact Summary"
                                    width="auto"
                                >
                                    <HBox
                                        id="summaryBox"
                                        class="sapUiSmallMargin"
                                        wrap="Wrap"
                                    >
                                        <ObjectStatus
                                            id="artifactStatus"
                                            title="Artifact"
                                            text="{= ${/fileName} || 'No artifact loaded' }"
                                            state="{= ${/hasFile} ? 'Success' : 'None' }"
                                            icon="sap-icon://document"
                                        />
                                        <ObjectStatus
                                            id="scriptCountStatus"
                                            title="Scripts"
                                            text="{= ${/scripts}.length || 0 }"
                                            state="Information"
                                            icon="sap-icon://syntax"
                                        />
                                        <ObjectStatus
                                            id="renameCountStatus"
                                            title="Renames"
                                            text="{/renameCount}"
                                            state="{= ${/renameCount} > 0 ? 'Warning' : 'None' }"
                                            icon="sap-icon://edit"
                                        />
                                        <ObjectStatus
                                            id="validationStatus"
                                            title="Validation"
                                            text="{/validationText}"
                                            state="{/validationState}"
                                            icon="sap-icon://status-positive"
                                        />
                                    </HBox>
                                </Panel>

                                <Panel
                                    id="scriptsPanel"
                                    headerText="Script Rename Workspace"
                                    width="auto"
                                    class="sapUiMediumMarginTop"
                                >
                                    <Table
                                        id="scriptsTable"
                                        items="{/scripts}"
                                        growing="true"
                                        noDataText="Load an artifact to review scripts."
                                    >
                                        <columns>
                                            <Column id="originalScriptColumn">
                                                <Text
                                                    id="originalScriptColumnText"
                                                    text="Original Script"
                                                />
                                            </Column>
                                            <Column
                                                id="usageColumn"
                                                width="9rem"
                                            >
                                                <Text
                                                    id="usageColumnText"
                                                    text="Usage"
                                                />
                                            </Column>
                                            <Column id="stepNamesColumn">
                                                <Text
                                                    id="stepNamesColumnText"
                                                    text="Palette / Step Reference"
                                                />
                                            </Column>
                                            <Column id="newScriptNameColumn">
                                                <Text
                                                    id="newScriptNameColumnText"
                                                    text="New Script Name"
                                                />
                                            </Column>
                                        </columns>
                                        <items>
                                            <ColumnListItem id="scriptRow">
                                                <cells>
                                                    <ObjectIdentifier
                                                        id="scriptObjectIdentifier"
                                                        title="{originalName}"
                                                        text="{originalPath}"
                                                    />
                                                    <ObjectStatus
                                                        id="usageStatus"
                                                        text="{usageStatus}"
                                                        state="{= ${used} ? 'Success' : 'Warning' }"
                                                        icon="{= ${used} ? 'sap-icon://accept' : 'sap-icon://alert' }"
                                                    />
                                                    <Text
                                                        id="stepNamesText"
                                                        text="{path: 'stepNames', formatter: '.formatStepNames'}"
                                                    />
                                                    <Input
                                                        id="newScriptNameInput"
                                                        value="{newName}"
                                                        valueLiveUpdate="true"
                                                        valueState="{valueState}"
                                                        valueStateText="{valueStateText}"
                                                        liveChange=".onScriptNameChanged"
                                                    />
                                                </cells>
                                            </ColumnListItem>
                                        </items>
                                    </Table>
                                </Panel>
                            </VBox>
                        </IconTabFilter>

                        <IconTabFilter
                            id="outputTab"
                            key="output"
                            icon="sap-icon://paper-plane"
                            text="Output"
                        >
                            <VBox
                                id="outputContainer"
                                class="sapUiMediumMargin"
                            >
                                <Panel
                                    id="outputPanel"
                                    headerText="Generate or Deploy"
                                    width="auto"
                                >
                                    <VBox
                                        id="outputBox"
                                        class="sapUiSmallMargin"
                                    >
                                        <MessageStrip
                                            id="outputMessage"
                                            text="Generate a modified ZIP for manual import, or deploy directly to CPI using the configured BTP Destination."
                                            type="Information"
                                            showIcon="true"
                                            class="sapUiSmallMarginBottom"
                                        />
                                        <OverflowToolbar id="outputToolbar">
                                            <Button
                                                id="generateButton"
                                                text="Generate Modified ZIP"
                                                icon="sap-icon://download"
                                                press=".onGenerateArtifact"
                                                enabled="{/canGenerate}"
                                            />
                                            <Button
                                                id="deployToCpiButton"
                                                text="Deploy to CPI"
                                                type="Accept"
                                                icon="sap-icon://upload-to-cloud"
                                                press=".onDeployToCpi"
                                                enabled="{/canDeployToCpi}"
                                            />
                                        </OverflowToolbar>
                                    </VBox>
                                </Panel>
                            </VBox>
                        </IconTabFilter>
                    </items>
                </IconTabBar>
            </VBox>
        </content>
    </Page>
</mvc:View>
